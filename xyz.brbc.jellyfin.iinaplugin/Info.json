{
  "name": "Jellyfin",
  "identifier": "xyz.brbc.jellyfin",
  "version": "1.2.1",
  "ghRepo": "ada-bee/jellyfin-iina",
  "ghVersion": 6,
  "description": "Browse and play media from your Jellyfin server",
  "author": {
    "name": "ada-bee"
  },
  "entry": "main.js",
  "globalEntry": "global.js",
  "sidebarTab": {
    "name": "Jellyfin"
  },
  "preferencesPage": "ui/preferences.html",
  "preferenceDefaults": {
    "skipSegmentsEnabled": true,
    "autoplayNextEpisodeEnabled": true
  },
  "permissions": [
    "network-request",
    "show-osd",
    "show-alert",
    "sidebar",
    "file-system",
    "video-overlay"
  ],
  "allowedDomains": ["*"]
}
